# ═══════════════════════════════════════════════════
#  ALPHADAWG ENV — TEMPLATE
# ═══════════════════════════════════════════════════
# Copy to `.env` locally. Paste the NEXT.JS block into Vercel
# (Settings → Environment Variables) for the deployed dashboard.
# The BACKEND-ONLY block stays in your local .env only — Vercel
# must NEVER see ENABLE_BACKGROUND_WORKERS=true or TELEGRAM_BOT_TOKEN.


# ═══════════════════════════════════════════════════
#  NEXT.JS — PASTE INTO VERCEL
# ═══════════════════════════════════════════════════

# ── Public (client-exposed, NEXT_PUBLIC_*) ────────
# CRITICAL: NEXT_PUBLIC_API_URL MUST stay empty on Vercel.
# lib/api.ts uses relative paths when empty → hits own Next.js API routes.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_HCS_TOPIC_ID=0.0.8497439
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ETHGlobal_Cannes_2026_Bot
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_OG_PROVIDER_ADDRESS=
NEXT_PUBLIC_OG_EXPLORER_URL=https://chainscan-galileo.0g.ai
NEXT_PUBLIC_INFT_CONTRACT=0x73e3016D0D3Bf2985c55860cd2A51FF017c2c874

# ── Hedera testnet (server-only) ──────────────────
# Get credentials: https://portal.hedera.com
OPERATOR_ID=0.0.XXXXXXX
OPERATOR_KEY=302e020100...
HCS_AUDIT_TOPIC_ID=0.0.XXXXXXX
HTS_FUND_TOKEN_ID=0.0.XXXXXXX

# Hedera EVM (ECDSA key for Smart Contracts + Naryo)
HEDERA_EVM_ACCOUNT_ID=0.0.XXXXXXX
HEDERA_EVM_PRIVATE_KEY=0x...
NARYO_AUDIT_CONTRACT_ADDRESS=0x...

# ── 0G Network ────────────────────────────────────
# Testnet tokens: https://hub.0g.ai
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_PRIVATE_KEY=0x...
OG_PROVIDER_ADDRESS=
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_FLOW_CONTRACT=
INFT_CONTRACT_ADDRESS=0x73e3016D0D3Bf2985c55860cd2A51FF017c2c874

# ── Arc (swap routing) ────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_UNISWAP_ROUTER=0xB2Be009Fce720B101E9367951423E0BF70600d36
ARC_WETH_ADDRESS=0x02344f2F981076A79E53222bF6f0822bF7f1Df0B
USDC_ARC_ADDRESS=0x3600000000000000000000000000000000000000
USDC_BASE_SEPOLIA_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ── Circle MPC (console.circle.com) ───────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# ── Supabase (PgBouncer pooler :6543 for Vercel) ──
# DATABASE_URL MUST be the pooler URL. DIRECT_URL is for Prisma migrations only.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ── Crypto (all sensitive — mark encrypted in Vercel) ─
# 32-byte hex for AES-256-CBC
SERVER_ENCRYPTION_KEY=
# BIP-44 HD seed for agent hot wallets
AGENT_MNEMONIC=

# ── x402 payments ─────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator

# ── Telegram bot (webhook mode for Vercel) ────────
# Bot token from @BotFather. Required for Telegram commands and approval flows.
TELEGRAM_BOT_TOKEN=
# Random string — Telegram echoes it in X-Telegram-Bot-Api-Secret-Token header
# on every webhook call. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ── Cron auth ─────────────────────────────────────
# Random string protecting /api/cron/heartbeat from public access.
# Vercel Cron auto-injects this as `Authorization: Bearer $CRON_SECRET`
# when declared as an env var on the Vercel project.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── App base URL (used by setup:webhook script) ───
# Set to your Vercel production URL — e.g. https://alphadawg.vercel.app
# (no trailing slash). Used only by scripts/set-telegram-webhook.ts.
APP_URL=

# ── Remote specialist agents (already on Fly) ─────
AGENT_URL_SENTIMENT=https://vm-sentiment.fly.dev
AGENT_URL_WHALE=https://vm-whale.fly.dev
AGENT_URL_MOMENTUM=https://vm-momentum.fly.dev
AGENT_URL_MEMECOIN_HUNTER=https://vm-memecoin-hunter.fly.dev
AGENT_URL_TWITTER_ALPHA=https://vm-twitter-alpha.fly.dev
AGENT_URL_DEFI_YIELD=https://vm-defi-yield.fly.dev
AGENT_URL_NEWS_SCANNER=https://vm-news-scanner.fly.dev
AGENT_URL_ONCHAIN_FORENSICS=https://vm-onchain-forensics.fly.dev
AGENT_URL_OPTIONS_FLOW=https://vm-options-flow.fly.dev
AGENT_URL_MACRO_CORRELATOR=https://vm-macro-correlator.fly.dev
AGENT_URL_ALPHA=https://vm-alpha.fly.dev
AGENT_URL_RISK=https://vm-risk.fly.dev
AGENT_URL_EXECUTOR=https://vm-executor.fly.dev

# ── Market data (optional, free tiers work without keys) ──
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
ETHERSCAN_API_URL=https://api.etherscan.io/api
ETHERSCAN_API_KEY=
FNG_API_URL=https://api.alternative.me/fng


# ═══════════════════════════════════════════════════
#  LOCAL-DEV ONLY — DO NOT PASTE TO VERCEL
# ═══════════════════════════════════════════════════
# With the webhook + cron routes deployed to Vercel, you no longer *need*
# `npm run backend` to run the Telegram bot or heartbeat. The variables
# below are only for the local `npm run backend` workflow if you still
# want to use it during development.

# Master switch for instrumentation.ts. MUST be unset/false on Vercel.
# Set to "true" ONLY in the process running `npm run backend` (src/index.ts).
# Never enable this alongside `npm run dev` — you'll get duplicate heartbeats.
# CAUTION: If the Vercel webhook is ALSO registered, local polling will get
# 409 Conflict from Telegram. Run `npm run setup:webhook -- delete` first
# if you want to run the bot locally in polling mode.
ENABLE_BACKGROUND_WORKERS=true

# Legacy: instrumentation.ts bot flag. Keep false — bot runs via src/index.ts.
NEXT_START_BOT=false

# Express backend port (only relevant if you re-enable the Express server)
SERVER_PORT=3001

# OpenClaw workspace (local filesystem path)
OPENCLAW_WORKSPACE=~/.openclaw/agents
