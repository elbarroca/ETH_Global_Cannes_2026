        "sandbox": { "mode": "all", "scope": "agent" },
        "tools": { "allow": ["read", "sessions_send"], "deny": ["write", "exec", "edit", "gateway", "cron"] }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "main-orchestrator", "alpha", "risk", "executor",
        "sentiment", "whale", "momentum",
        "memecoin-hunter", "twitter-alpha", "defi-yield",
        "news-scanner", "onchain-forensics", "options-flow", "macro-correlator"
      ]
    }
  },
  "session": {
    "agentToAgent": {
      "maxPingPongTurns": 5
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "denylist"
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tools": {
      "allow": ["sessions_send", "sessions_list", "sessions_history"]
    },
    "reload": {
      "mode": "hybrid"
    }
  }
}
