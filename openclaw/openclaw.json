{
  "name": "AlphaDawg",
  "version": "2.0.0",
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-sonnet-4-6" },
      "heartbeat": {
        "every": "5m",
        "isolatedSession": true,
        "lightContext": true,
        "target": "last"
      }
    },
    "list": [
      {
        "id": "main-orchestrator",
        "default": true,
        "identity": { "name": "AlphaDawg Orchestrator", "emoji": "🐾" },
        "workspace": "./openclaw/main-agent",
        "model": { "primary": "anthropic/claude-sonnet-4-6" },
        "subagents": {
          "allowAgents": [
            "sentiment", "whale", "momentum",
            "alpha", "risk", "executor",
            "memecoin-hunter", "twitter-alpha", "defi-yield",
            "news-scanner", "onchain-forensics", "options-flow", "macro-correlator"
          ]
        }
      },
      {
        "id": "sentiment",
        "identity": { "name": "SentimentBot", "emoji": "🧠" },
        "workspace": "./openclaw/sentiment-agent",
        "model": { "primary": "anthropic/claude-sonnet-4-6" },
        "sandbox": { "mode": "all", "scope": "agent" },
        "tools": { "allow": ["read", "sessions_send"], "deny": ["write", "exec", "edit", "gateway", "cron"] }
      },
      {
        "id": "whale",
        "identity": { "name": "WhaleEye", "emoji": "🐋" },
        "workspace": "./openclaw/whale-agent",
        "model": { "primary": "anthropic/claude-sonnet-4-6" },
        "sandbox": { "mode": "all", "scope": "agent" },
