# Backend-only code — NOT reachable from app/** on Vercel.
# Long-running / port-binding services stay excluded. Anything imported by
# `app/api/**` (Telegram webhook, cron heartbeat) must NOT be listed here or
# the build fails with "Can't resolve".

# Long-running / port-binding backend services
src/agents/specialist-server.ts
src/index.ts
src/api/

# Build / deploy tooling
scripts/
naryo/
fly/
hardhat.config.cjs

# Smart contract artifacts (deployed separately)
contracts/
artifacts/
cache/
test/
*.sol

# Docs and progress tracking
progress/
docs/
openclaw/

# Editor / local
.vscode/
.idea/
*.log
