generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String        @id
  walletAddress      String        @unique @map("wallet_address")
  proxyWallet        Json          @default("{}") @map("proxy_wallet")
  telegram           Json          @default("{\"chatId\": null, \"username\": null, \"verified\": false, \"notifyPreference\": \"every_cycle\"}")
  agent              Json          @default("{\"active\": false, \"lastCycleAt\": null, \"lastCycleId\": 0, \"riskProfile\": \"balanced\", \"maxTradePercent\": 10}")
  fund               Json          @default("{\"currentNav\": 0, \"depositedUsdc\": 0, \"htsShareBalance\": 0}")
  inftTokenId        Int?          @map("inft_token_id")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  hot_wallet_index   Int?
  hot_wallet_address String?
  actions            AgentAction[]
  cycles             Cycle[]
  hiredAgents        UserHiredAgent[]
  pendingCycles      PendingCycle[]
  chatMessages       ChatMessage[]

  @@index([walletAddress], map: "idx_users_wallet")
  @@map("users")
}

model Cycle {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String        @map("user_id")
  cycleNumber      Int           @map("cycle_number")
  goal             String?       @db.Text
  payments         Json?
  specialists      Json          @default("[]")
  alphaAction      String?       @map("alpha_action")
  alphaPct         Int?          @map("alpha_pct")
  alphaAttestation String?       @map("alpha_attestation")
  riskChallenge    String?       @map("risk_challenge")
  riskMaxPct       Int?          @map("risk_max_pct")
  riskAttestation  String?       @map("risk_attestation")
  execAction       String?       @map("exec_action")
  execPct          Int?          @map("exec_pct")
  execStopLoss     String?       @map("exec_stop_loss")
  execAttestation  String?       @map("exec_attestation")
  alphaReasoning   String?       @map("alpha_reasoning")
  riskReasoning    String?       @map("risk_reasoning")
  execReasoning    String?       @map("exec_reasoning")
  decision         String?
  asset            String?
  decisionPct      Int?          @map("decision_pct")
  hcsSeqNum        Int?          @map("hcs_seq_num")
  hashscanUrl      String?       @map("hashscan_url")
  storageHash      String?       @map("storage_hash")
  totalCostUsd     Float?        @map("total_cost_usd")
  navAfter         Float?        @map("nav_after")
  swapTxHash       String?       @map("swap_tx_hash")
  swapChain        String?       @default("arc-testnet") @map("swap_chain")
  swapAmount       String?       @map("swap_amount")
  swapAssetIn      String?       @map("swap_asset_in")
  swapAssetOut     String?       @map("swap_asset_out")
  swapExplorerUrl  String?       @map("swap_explorer_url")
  debateDurationMs Int?          @map("debate_duration_ms")
  debateTurns      Int?          @map("debate_turns")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  actions          AgentAction[]
  transcripts      DebateTranscript[]
  user             User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, cycleNumber], map: "idx_cycles_user_cycle")
  @@map("cycles")
}

model AgentAction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id")
  cycleId         String?  @map("cycle_id") @db.Uuid
  actionType      String   @map("action_type")
  agentName       String?  @map("agent_name")
  status          String   @default("success")
  payload         Json?
  attestationHash String?  @map("attestation_hash")
  teeVerified     Boolean? @map("tee_verified")
  paymentAmount   String?  @map("payment_amount")
  paymentNetwork  String?  @map("payment_network")
  paymentTxHash   String?  @map("payment_tx_hash")
  durationMs      Int?     @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  cycle           Cycle?   @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt], map: "idx_agent_actions_created")
  @@index([cycleId], map: "idx_agent_actions_cycle")
  @@index([userId, actionType], map: "idx_agent_actions_user_type")
  @@map("agent_actions")
}

model MarketplaceAgent {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String            @unique
  endpoint     String
  price        String            @default("$0.001")
  tags         String[]          @default([])
  reputation   Int               @default(500)
  totalHires   Int               @default(0) @map("total_hires")
  correctCalls Int               @default(0) @map("correct_calls")
  inftTokenId  Int?              @map("inft_token_id")
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  hiredBy      UserHiredAgent[]

  specialistType  String?           @default("analysis") @map("specialist_type")
  dataSources     String[]          @default([]) @map("data_sources")
  openclawAgentId String?           @map("openclaw_agent_id")
  walletAddress   String?           @map("wallet_address")
  storageRootHash String?           @map("storage_root_hash")
  storageUri      String?           @map("storage_uri")
  mintTxHash      String?           @map("mint_tx_hash")

  @@map("marketplace_agents")
}

// Per-pick performance tracking for specialists.
//
// When a specialist emits a pick (sentiment picks "BUY UNI 80%"), we snapshot
// the asset's current USD price + timestamp. A later evaluator job wakes up
// Δt after the pick (e.g. 24h) and scores it: did the price move in the
// direction the specialist predicted? Correct picks boost the specialist's
// marketplace reputation; wrong picks cut it. Over enough cycles, the hire/
// fire rotation (see src/marketplace/hire-fire.ts, planned) prunes consistently
// bad specialists and hires replacements from the marketplace.
//
// See docs/SYSTEM_STATE_AND_FIXES.md Problem 5 for the full design.
model SpecialistPickEntry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId         String   @map("cycle_id") @db.Uuid
  cycleNumber     Int      @map("cycle_number")
  userId          String   @map("user_id")
  specialistName  String   @map("specialist_name")
  asset           String   // ticker — "WETH", "UNI", etc.
  signal          String   // BUY | SELL | HOLD
  confidence      Int      // 0-100
  reason          String   @db.Text
  entryPriceUsd   Float    @map("entry_price_usd")
  enteredAt       DateTime @default(now()) @map("entered_at") @db.Timestamptz(6)
  // Evaluation fields — populated by pick-evaluator.ts on a delayed tick
  evaluatedAt     DateTime? @map("evaluated_at") @db.Timestamptz(6)
  exitPriceUsd    Float?   @map("exit_price_usd")
  pnlPct          Float?   @map("pnl_pct")
  correct         Boolean? // did the signal direction match the price movement?
  scored          Boolean  @default(false)

  @@index([specialistName, enteredAt], map: "idx_pick_entries_specialist")
  @@index([cycleId], map: "idx_pick_entries_cycle")
  @@index([asset, enteredAt], map: "idx_pick_entries_asset")
  @@index([scored, enteredAt], map: "idx_pick_entries_scored")
  @@map("specialist_pick_entries")
}

model DebateTranscript {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId         String   @map("cycle_id") @db.Uuid
  userId          String   @map("user_id")
  turnNumber      Int      @map("turn_number")
  phase           String   // intelligence, opening, rebuttal, decision, execution
  fromAgent       String   @map("from_agent")
  toAgent         String?  @map("to_agent")
  messageContent  String   @map("message_content")
  responseContent String?  @map("response_content")
  attestationHash String?  @map("attestation_hash")
  teeVerified     Boolean? @default(false) @map("tee_verified")
  durationMs      Int?     @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  cycle           Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId, turnNumber], map: "idx_debate_transcripts_cycle_turn")
  @@index([userId, createdAt], map: "idx_debate_transcripts_user")
  @@map("debate_transcripts")
}

model UserHiredAgent {
  id       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String          @map("user_id")
  agentId  String          @map("agent_id") @db.Uuid
  hiredAt  DateTime        @default(now()) @map("hired_at") @db.Timestamptz(6)
  active   Boolean         @default(true)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([userId], map: "idx_user_hired_agents_user")
  @@index([agentId], map: "idx_user_hired_agents_agent")
  @@map("user_hired_agents")
}

model PendingCycle {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id")
  cycleNumber   Int       @map("cycle_number")
  goal          String?   @db.Text
  status        String    @default("PENDING_APPROVAL")
  origin        String    @default("ui")
  specialists   Json      @default("[]")
  debate        Json      @default("{}")
  compactRecord Json      @default("{}") @map("compact_record")
  richRecord    Json?     @map("rich_record")
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolvedBy    String?   @map("resolved_by")
  modifiedPct   Int?      @map("modified_pct")
  telegramMsgId Int?      @map("telegram_msg_id")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, status], map: "idx_pending_cycles_user_status")
  @@index([expiresAt], map: "idx_pending_cycles_expires")
  @@map("pending_cycles")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  role      String   // "user" | "assistant"
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_chat_messages_user")
  @@map("chat_messages")
}

model NaryoEvent {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source        String
  chain         String
  eventType     String            @map("event_type")
  txHash        String?           @map("tx_hash")
  decodedData   Json?             @map("decoded_data")
  rawPayload    Json              @map("raw_payload")
  correlationId String?           @map("correlation_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  correlation   NaryoCorrelation? @relation(fields: [correlationId], references: [id])

  @@index([source, createdAt], map: "idx_naryo_events_source")
  @@index([chain, createdAt], map: "idx_naryo_events_chain")
  @@index([correlationId], map: "idx_naryo_events_correlation")
  @@map("naryo_events")
}

model NaryoCorrelation {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String
  chains      String[]
  proofTxHash String?      @map("proof_tx_hash")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  events      NaryoEvent[]

  @@map("naryo_correlations")
}
