# ═══════════════════════════════════════
# Single AlphaDawg Agent — Fly.io deployment
# Express + x402 paywall + 0G sealed inference
# Deploy: fly deploy --dockerfile fly/Dockerfile.agent
# ═══════════════════════════════════════

FROM node:22-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3 make g++ curl openssl \
    && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json* ./
COPY prisma ./prisma/

RUN npm ci --legacy-peer-deps
RUN npx prisma generate

# Copy agent source
COPY src ./src
COPY tsconfig.json ./
COPY openclaw ./openclaw

RUN npm install -g tsx

# Each agent runs on port 8080 (Fly.io default)
EXPOSE 8080
ENV PORT=8080

# AGENT_NAME env var determines which specialist to run
# Set via: fly secrets set AGENT_NAME=sentiment
CMD ["tsx", "src/agents/fly-agent-server.ts"]
